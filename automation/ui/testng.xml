<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="InvenTree UI Test Suite" parallel="methods" thread-count="3" verbose="1">

    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <!-- Smoke Test Suite - Critical functionality -->
    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <packages>
            <package name="com.inventree.ui.tests"/>
        </packages>
    </test>

    <!-- Regression Test Suite - Full test coverage -->
    <test name="Regression Tests">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <packages>
            <package name="com.inventree.ui.tests"/>
        </packages>
    </test>

    <!-- Part Management Tests -->
    <test name="Part Management Tests">
        <classes>
            <class name="com.inventree.ui.tests.PartCreationTest"/>
        </classes>
    </test>

</suite>
