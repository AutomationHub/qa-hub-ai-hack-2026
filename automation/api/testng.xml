<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="InvenTree API Test Suite" parallel="methods" thread-count="3" verbose="1">

    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
    </listeners>

    <!-- Smoke Test Suite - Critical API functionality -->
    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <packages>
            <package name="com.inventree.api.tests"/>
        </packages>
    </test>

    <!-- Regression Test Suite - Full test coverage -->
    <test name="Regression Tests">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <packages>
            <package name="com.inventree.api.tests"/>
        </packages>
    </test>

    <!-- Negative Test Suite - Error handling and validation -->
    <test name="Negative Tests">
        <groups>
            <run>
                <include name="negative"/>
            </run>
        </groups>
        <packages>
            <package name="com.inventree.api.tests"/>
        </packages>
    </test>

    <!-- Part CRUD Tests -->
    <test name="Part CRUD Tests">
        <classes>
            <class name="com.inventree.api.tests.PartCrudTest"/>
        </classes>
    </test>

</suite>
