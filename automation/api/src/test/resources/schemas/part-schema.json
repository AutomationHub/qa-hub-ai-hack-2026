{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["pk", "name", "category", "active"],
  "properties": {
    "pk": {
      "type": "integer"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "category": {
      "type": "integer"
    },
    "IPN": {
      "type": ["string", "null"]
    },
    "revision": {
      "type": ["string", "null"]
    },
    "keywords": {
      "type": ["string", "null"]
    },
    "units": {
      "type": ["string", "null"]
    },
    "link": {
      "type": ["string", "null"]
    },
    "active": {
      "type": "boolean"
    },
    "virtual": {
      "type": "boolean"
    },
    "is_template": {
      "type": "boolean"
    },
    "assembly": {
      "type": "boolean"
    },
    "component": {
      "type": "boolean"
    },
    "trackable": {
      "type": "boolean"
    },
    "purchaseable": {
      "type": "boolean"
    },
    "saleable": {
      "type": "boolean"
    },
    "minimum_stock": {
      "type": ["integer", "null"]
    },
    "notes": {
      "type": ["string", "null"]
    }
  }
}
