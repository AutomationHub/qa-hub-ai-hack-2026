{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["count", "results"],
  "properties": {
    "count": {
      "type": "integer"
    },
    "next": {
      "type": ["string", "null"]
    },
    "previous": {
      "type": ["string", "null"]
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pk", "name", "category", "active"],
        "properties": {
          "pk": {
            "type": "integer"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "category": {
            "type": "integer"
          },
          "active": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
